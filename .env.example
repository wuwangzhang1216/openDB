# FileDB Configuration
# Copy this to .env and adjust as needed

# Database
FILEDB_DATABASE_URL=postgresql://opendb:opendb@localhost:5432/opendb
FILEDB_DB_POOL_MIN=5
FILEDB_DB_POOL_MAX=20

# File storage
FILEDB_FILE_STORAGE_PATH=./data
FILEDB_MAX_FILE_SIZE=104857600
FILEDB_SYNC_PROCESSING_LIMIT=52428800

# OCR
FILEDB_OCR_ENABLED=true
FILEDB_OCR_LANGUAGES=eng+chi_sim+chi_tra

# Server
FILEDB_HOST=0.0.0.0
FILEDB_PORT=8000
